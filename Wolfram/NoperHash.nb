Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "TestSuite", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"TestSuite", "=", 
   RowBox[{"Function", "[", 
    RowBox[{
     RowBox[{"{", "nf", "}"}], ",", "\[IndentingNewLine]", "\t", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "tests", "}"}], ",", "\n", "\t\t", 
       RowBox[{
        RowBox[{"tests", "=", 
         RowBox[{"<|", "|>"}]}], ";", "\n", "\t\t", "\n", "\t\t", 
        RowBox[{
         RowBox[{"tests", "[", "\"\<mean\>\"", "]"}], "=", 
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"s", ",", "s2"}], "}"}], ",", "\n", "\t\t\t", 
           RowBox[{
            RowBox[{"s", "=", 
             RowBox[{"{", 
              RowBox[{
              "5", ",", "6", ",", "4.6", ",", "6.3", ",", "5", ",", "4.3", 
               ",", "5.2"}], "}"}]}], ";", "\[IndentingNewLine]", "\t\t\t", 
            RowBox[{"s2", "=", 
             RowBox[{"{", 
              RowBox[{
              "5", ",", "5.2", ",", "4.6", ",", "6.3", ",", "5", ",", "4.3", 
               ",", "5.2"}], "}"}]}], ";", "\n", "\t\t\t", 
            RowBox[{
             RowBox[{
              RowBox[{"Mean", "[", "s", "]"}], "\[NotEqual]", 
              RowBox[{"Mean", "[", "s2", "]"}]}], "&&", "\n", "\t\t\t", 
             RowBox[{
              RowBox[{"StandardDeviation", "[", "s", "]"}], "\[NotEqual]", 
              RowBox[{"StandardDeviation", "[", "s2", "]"}]}], "&&", "\n", 
             "\t\t\t", 
             RowBox[{
              RowBox[{"nf", "[", "s", "]"}], "\[NotEqual]", 
              RowBox[{"nf", "[", "s2", "]"}]}]}]}]}], "\n", "\t\t", "]"}]}], 
        ";", "\n", "\t\t", "\n", "\t\t", 
        RowBox[{
         RowBox[{"tests", "[", "\"\<stddev\>\"", "]"}], "=", 
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"s", ",", "s2", ",", "s3"}], "}"}], ",", "\n", "\t\t\t", 
           RowBox[{
            RowBox[{"s", "=", 
             RowBox[{"{", 
              RowBox[{
              "5", ",", "6", ",", "4.6", ",", "6.3", ",", "5", ",", "4.3", 
               ",", "5.2"}], "}"}]}], ";", "\[IndentingNewLine]", "\t\t\t", 
            RowBox[{"s2", "=", 
             RowBox[{"{", 
              RowBox[{
              "5", ",", "5.2", ",", "5.4", ",", "6.3", ",", "5", ",", "4.3", 
               ",", "5.2"}], "}"}]}], ";", "\[IndentingNewLine]", "\t\t\t", 
            RowBox[{"s3", "=", 
             RowBox[{"{", 
              RowBox[{
              "5", ",", "6", ",", "6.3", ",", "4.6", ",", "5", ",", "4.3", 
               ",", "5.2"}], "}"}]}], ";", "\n", "\t\t\t", 
            RowBox[{
             RowBox[{
              RowBox[{"Mean", "[", "s", "]"}], "==", 
              RowBox[{"Mean", "[", "s2", "]"}], "==", 
              RowBox[{"Mean", "[", "s3", "]"}]}], "&&", "\n", "\t\t\t", 
             RowBox[{
              RowBox[{"StandardDeviation", "[", "s", "]"}], "\[NotEqual]", 
              RowBox[{"StandardDeviation", "[", "s2", "]"}]}], "&&", "\n", 
             "\t\t\t", 
             RowBox[{
              RowBox[{"StandardDeviation", "[", "s", "]"}], "==", 
              RowBox[{"StandardDeviation", "[", "s3", "]"}]}], "&&", "\n", 
             "\t\t\t", 
             RowBox[{
              RowBox[{"nf", "[", "s", "]"}], "\[NotEqual]", 
              RowBox[{"nf", "[", "s2", "]"}], "\[NotEqual]", 
              RowBox[{"nf", "[", "s3", "]"}]}]}]}]}], "\n", "\t\t", "]"}]}], 
