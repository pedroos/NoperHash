           RowBox[{"Return", "[", "0", "]"}]}], "]"}], ";", "\n", "\t", 
         RowBox[{"Fold", "[", "\[IndentingNewLine]", "\t\t", 
          RowBox[{
           RowBox[{"Function", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"x", ",", "y"}], "}"}], ",", "\n", "\t\t\t", 
             RowBox[{
              RowBox[{"xA", "=", 
               RowBox[{"Abs", "[", "x", "]"}]}], ";", "\n", "\t\t\t", 
              RowBox[{"yA", "=", 
               RowBox[{"Abs", "[", "y", "]"}]}], ";", "\n", "\t\t\t", 
              RowBox[{"yMag", "=", 
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"yA", "\[NotEqual]", "0"}], ",", 
