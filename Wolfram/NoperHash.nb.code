In[22]:= Clear[SymTest]
SymTest = Function[nf, Module[{s, s2, s3, s4},
    	s = {5, 62, 4.6, 6.2, 5, 4.3, 5.2};
    	s2 = {5, 6.2, 4.6, 62, 5, 4.3, 5.2};
    	s3 = {5, 62, 6.2, 4.6, 5, 4.3, 5.2};
    	Table[Print[set -> nf[set]], {set, {s, s2, s3}}];
    	Print[nf[s] == nf[s2] && nf[s2] != nf[s3]]
    ]];

