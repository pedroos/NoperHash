In[3]:= Clear[NormMag, NormOperFull, NormOperIndex];
NormMag = Function[x,
   	x/10^MantissaExponent[x][[2]]
   ];
(*main function that returns the index.*)
NormOperIndex = Function[set, Module[{meanMag, xA, yA, xMag, yMag},
    	meanMag = N[NormMag[Mean[set]]];
    	If[meanMag == 0 && StandardDeviation[set] == 0, Return[0]];
    	Fold[
     		Function[{x, y},
      			xA = Abs[x];
      			yA = Abs[y];
      			yMag = If[yA != 0, N[NormMag[yA]], meanMag];
      			xMag = N[NormMag[xA]];
      			yMag^xMag
      		],
     	meanMag, Reverse[set]]
    ]];
(*use for debugging purposes, returns the list of all intermediate \
values.*)
NormOperFull = Function[set, Module[{meanMag, xA, yA, xMag, yMag},
    	meanMag = N[NormMag[Mean[set]]];
    	If[meanMag == 0 && StandardDeviation[set] == 0, Return[0]];
    	Rest[FoldList[
      		Function[{x, y},
       			xA = Abs[x];
       			yA = Abs[y];
       			yMag = If[yA != 0, N[NormMag[yA]], meanMag];
       			xMag = N[NormMag[xA]];
       			yMag^xMag
       		],
      	meanMag, Reverse[set]]]
    ]];

